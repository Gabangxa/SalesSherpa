# Database — auto-injected by Railway Postgres plugin, or paste your connection string
DATABASE_URL=

# Session — generate a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Google OAuth — from console.cloud.google.com
SALES_SHERPA_GOOGLE_CLIENT_ID=
SALES_SHERPA_GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://salessherpa-production.up.railway.app/api/auth/google/callback

# Google AI (Gemini)
GOOGLE_AI_KEY=

# Email — optional, app degrades gracefully without it
SENDGRID_API_KEY=
# Must be a verified sender in your SendGrid account
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Polar.sh billing — https://sandbox.polar.sh (use sandbox.polar.sh for testing)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# Use the Product ID from the Polar dashboard (not the price ID)
POLAR_PRO_PRODUCT_ID=
POLAR_STARTER_PRODUCT_ID=
# 'sandbox' for testing, 'production' for live
POLAR_SERVER=sandbox

# Runtime
NODE_ENV=production
# Used for building absolute URLs (email links, OAuth redirects)
BASE_URL=https://salessherpa-production.up.railway.app
