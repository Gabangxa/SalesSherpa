# Database — auto-injected by Railway Postgres plugin, or paste your connection string
DATABASE_URL=

# Session — generate a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Google OAuth — from console.cloud.google.com
SALES_SHERPA_GOOGLE_CLIENT_ID=
SALES_SHERPA_GOOGLE_CLIENT_SECRET=
# Set this to your Railway domain once deployed
GOOGLE_CALLBACK_URL=https://your-app.up.railway.app/api/auth/google/callback

# Google AI (Gemini)
GOOGLE_AI_KEY=

# Email — optional, app degrades gracefully without it
SENDGRID_API_KEY=

# Runtime
NODE_ENV=production
# Used for building absolute URLs (email links, OAuth redirects)
BASE_URL=https://your-app.up.railway.app
